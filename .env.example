# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=saas_password
POSTGRES_DB=saas_db
POSTGRES_PORT=5432
DATABASE_URL="postgresql://saas_user:saas_password@localhost:5432/saas_db?schema=public"

# =============================================================================
# REDIS
# =============================================================================
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# =============================================================================
# API
# =============================================================================
API_PORT=3333
NODE_ENV=development

# =============================================================================
# JWT
# Gere um secret seguro com: openssl rand -base64 32
# =============================================================================
JWT_SECRET=change-this-to-a-random-secret-with-32-chars-minimum
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# CORS
# Em produção coloque a URL real do seu frontend
# =============================================================================
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# SENTRY
# Crie um projeto em https://sentry.io e cole o DSN aqui
# Deixe vazio para desativar o monitoramento
# =============================================================================
SENTRY_DSN=

# =============================================================================
# WEB (Next.js)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3333