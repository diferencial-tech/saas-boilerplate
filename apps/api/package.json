{
  "name": "@saas/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:seed": "tsx --env-file=../../.env src/database/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "5",
    "@saas/logger": "workspace:*",
    "@saas/shared": "workspace:*",
    "@saas/validators": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "dotenv-cli": "^11.0.0",
    "prisma": "5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}